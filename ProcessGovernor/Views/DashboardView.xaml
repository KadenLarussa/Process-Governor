<UserControl x:Class="ProcessGovernor.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="330" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Dashboard" Style="{StaticResource PageTitle}" />
                <TextBlock Text="Live process view with safe actions and low-overhead refresh." Style="{StaticResource MutedText}" />
            </StackPanel>
            <StackPanel Grid.Column="1">
                <TextBlock Text="Search" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,5" />
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
        </Grid>

        <UniformGrid Grid.Row="1" Columns="6" Margin="0,0,0,10">
            <Border Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="CPU" Style="{StaticResource MutedText}" />
                    <TextBlock Text="{Binding Summary.CpuDisplay}" FontSize="22" FontWeight="SemiBold" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="RAM" Style="{StaticResource MutedText}" />
                    <TextBlock Text="{Binding Summary.MemoryDisplay}" FontSize="22" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding Summary.MemoryDetail}" Foreground="{StaticResource MutedTextBrush}" FontSize="11" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="Disk" Style="{StaticResource MutedText}" />
                    <TextBlock Text="{Binding Summary.DiskActivity}" FontSize="18" FontWeight="SemiBold" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="GPU" Style="{StaticResource MutedText}" />
                    <TextBlock Text="{Binding Summary.GpuUsage}" FontSize="18" FontWeight="SemiBold" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="Processes" Style="{StaticResource MutedText}" />
                    <TextBlock Text="{Binding Summary.ProcessCount}" FontSize="22" FontWeight="SemiBold" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="Uptime" Style="{StaticResource MutedText}" />
                    <TextBlock Text="{Binding Summary.UptimeDisplay}" FontSize="22" FontWeight="SemiBold" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding ProcessesView}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Extended"
                  SelectionUnit="FullRow"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  ScrollViewer.CanContentScroll="True">
            <DataGrid.RowStyle>
                <Style TargetType="{x:Type DataGridRow}" BasedOn="{StaticResource {x:Type DataGridRow}}">
                    <EventSetter Event="PreviewMouseRightButtonDown" Handler="DataGridRow_PreviewMouseRightButtonDown" />
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Kill Process"
                              Command="{Binding PlacementTarget.DataContext.KillProcessCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                              CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                    <MenuItem Header="End Process Tree"
                              Command="{Binding PlacementTarget.DataContext.EndProcessTreeCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                              CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                    <Separator />
                    <MenuItem Header="Open File Location"
                              Command="{Binding PlacementTarget.DataContext.OpenFileLocationCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                              CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                    <MenuItem Header="Copy Path"
                              Command="{Binding PlacementTarget.DataContext.CopyPathCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                              CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                    <Separator />
                    <MenuItem Header="Set Priority">
                        <MenuItem Header="Idle"
                                  Command="{Binding PlacementTarget.DataContext.SetIdlePriorityCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                        <MenuItem Header="Below Normal"
                                  Command="{Binding PlacementTarget.DataContext.SetBelowNormalPriorityCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                        <MenuItem Header="Normal"
                                  Command="{Binding PlacementTarget.DataContext.SetNormalPriorityCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                        <MenuItem Header="Above Normal"
                                  Command="{Binding PlacementTarget.DataContext.SetAboveNormalPriorityCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                        <MenuItem Header="High"
                                  Command="{Binding PlacementTarget.DataContext.SetHighPriorityCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                    </MenuItem>
                </ContextMenu>
            </DataGrid.ContextMenu>
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="Process" SortMemberPath="Name" Width="220">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                <Border Background="#3B2F15"
                                        BorderBrush="{StaticResource WarningBrush}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Margin="8,0,0,0"
                                        Padding="5,1"
                                        Visibility="{Binding RequiresElevationForActions, Converter={StaticResource BoolToVisibilityConverter}}"
                                        ToolTip="Some actions may require administrator elevation.">
                                    <TextBlock Text="ADMIN" Foreground="{StaticResource WarningBrush}" FontSize="10" FontWeight="SemiBold" />
                                </Border>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="PID" Binding="{Binding ProcessId}" Width="80" />
                <DataGridTextColumn Header="CPU" Binding="{Binding CpuDisplay}" SortMemberPath="CpuUsagePercent" Width="90" />
                <DataGridTextColumn Header="RAM" Binding="{Binding MemoryDisplay}" SortMemberPath="WorkingSetBytes" Width="110" />
                <DataGridTextColumn Header="Disk" Binding="{Binding DiskUsage}" Width="105" />
                <DataGridTextColumn Header="GPU" Binding="{Binding GpuUsage}" Width="105" />
                <DataGridTextColumn Header="Priority" Binding="{Binding PriorityDisplay}" Width="115" />
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100" />
                <DataGridTextColumn Header="Start Time" Binding="{Binding StartTimeDisplay}" Width="165" />
                <DataGridTextColumn Header="Executable Path" Binding="{Binding ExecutablePathDisplay}" Width="*" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
