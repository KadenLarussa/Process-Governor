<Window x:Class="ProcessGovernor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{Binding AppName}"
        Height="860"
        Width="1380"
        MinHeight="640"
        MinWidth="1040"
        WindowStartupLocation="CenterScreen">
    <Grid x:Name="RootShell" Background="{StaticResource WindowBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border x:Name="Sidebar"
                Grid.Column="0"
                Background="#111820"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="0,0,1,0"
                Padding="16">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,20">
                    <TextBlock Text="{Binding AppName}" FontSize="22" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding ElevationDisplay}" Foreground="{StaticResource MutedTextBrush}" Margin="0,4,0,0" />
                </StackPanel>

                <ListBox ItemsSource="{Binding NavigationItems}"
                         SelectedItem="{Binding SelectedNavigationItem}"
                         Margin="0,8,0,0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Width="22" Height="22" CornerRadius="6" Background="#1D5269">
                                    <TextBlock Text="{Binding Glyph}" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold" />
                                </Border>
                                <TextBlock Grid.Column="1" Text="{Binding Title}" VerticalAlignment="Center" FontWeight="SemiBold" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <ContentControl x:Name="PageHost"
                        Grid.Column="1"
                        Content="{Binding CurrentPage}"
                        Margin="22" />
    </Grid>
</Window>
